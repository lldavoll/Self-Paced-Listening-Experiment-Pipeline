      <CodeComponent name="main_code" plugin="None">
        <Param val="" valType="extendedCode" updates="constant" name="Before Experiment"/>
        <Param val="" valType="extendedCode" updates="constant" name="Before JS Experiment"/>
        <Param val="from psychopy import event, core" valType="extendedCode" updates="constant" name="Begin Experiment"/>
        <Param val="import {core, event} from 'psychopy';&amp;#10;" valType="extendedCode" updates="constant" name="Begin JS Experiment"/>
        <Param val="if ((segment_number === 8)) {&amp;#10;    continueRoutine = false;&amp;#10;}&amp;#10;min_wait_time = (duration_ms / 1000);&amp;#10;routine_clock = new util.Clock();&amp;#10;psychoJS.eventManager.clearEvents({&quot;eventType&quot;: &quot;keyboard&quot;});&amp;#10;space_pressed = false;&amp;#10;spacebar_rt = null;&amp;#10;audio_finished = false;&amp;#10;" valType="extendedCode" updates="constant" name="Begin JS Routine"/>
        <Param val="if segment_number == 8:&amp;#10;    continueRoutine = False&amp;#10;    &amp;#10;# Get audio duration in seconds from CSV&amp;#10;min_wait_time = duration_ms / 1000&amp;#10;&amp;#10;# Start a clock for the trial&amp;#10;routine_clock = core.Clock()&amp;#10;&amp;#10;# Prevent spacebar presses before the audio finishes&amp;#10;event.clearEvents(eventType='keyboard')&amp;#10;&amp;#10;# Variables to track spacebar press&amp;#10;space_pressed = False&amp;#10;spacebar_rt = None&amp;#10;audio_finished = False&amp;#10;&amp;#10;" valType="extendedCode" updates="constant" name="Begin Routine"/>
        <Param val="Auto-&gt;JS" valType="str" updates="None" name="Code Type"/>
        <Param val="current_time = routine_clock.getTime()&amp;#10;&amp;#10;# Mark when audio has finished playing&amp;#10;if current_time &gt;= min_wait_time and not audio_finished:&amp;#10;    audio_finished = True&amp;#10;    event.clearEvents(eventType='keyboard')&amp;#10;    print(f&quot;Audio finished at: {current_time:.3f}s, now accepting spacebar.&quot;)&amp;#10;&amp;#10;# Allow spacebar only after audio ends&amp;#10;if audio_finished and not space_pressed:&amp;#10;    keys = event.getKeys(keyList=['space'], timeStamped=routine_clock)&amp;#10;    if keys:&amp;#10;        space_pressed = True&amp;#10;        spacebar_rt = keys[0][1]  # in seconds&amp;#10;&amp;#10;        # Calculate timing&amp;#10;        spacebar_rt_ms = spacebar_rt * 1000&amp;#10;        reaction_time_ms = spacebar_rt_ms - duration_ms&amp;#10;&amp;#10;        print(f&quot;Pressed SPACE at {spacebar_rt:.3f}s ({reaction_time_ms:.2f} ms after audio).&quot;)&amp;#10;&amp;#10;        # Save to PsychoPy's data file&amp;#10;        thisExp.addData('spacebar_rt_ms', spacebar_rt_ms)&amp;#10;        thisExp.addData('reaction_time_ms', reaction_time_ms)&amp;#10;        continueRoutine = False&amp;#10;" valType="extendedCode" updates="constant" name="Each Frame"/>
        <Param val="current_time = routine_clock.getTime();&amp;#10;if (((current_time &gt;= min_wait_time) &amp;&amp; (! audio_finished))) {&amp;#10;    audio_finished = true;&amp;#10;    psychoJS.eventManager.clearEvents({&quot;eventType&quot;: &quot;keyboard&quot;});&amp;#10;    console.log(`Audio finished at: ${util.pad(Number.parseFloat(current_time).toFixed(3), 1)}s, now accepting spacebar.`);&amp;#10;}&amp;#10;if ((audio_finished &amp;&amp; (! space_pressed))) {&amp;#10;    keys = psychoJS.eventManager.getKeys({&quot;keyList&quot;: [&quot;space&quot;], &quot;timeStamped&quot;: routine_clock});&amp;#10;    if (keys) {&amp;#10;        space_pressed = true;&amp;#10;        spacebar_rt = keys[0][1];&amp;#10;        spacebar_rt_ms = (spacebar_rt * 1000);&amp;#10;        reaction_time_ms = (spacebar_rt_ms - duration_ms);&amp;#10;        console.log(`Pressed SPACE at ${util.pad(Number.parseFloat(spacebar_rt).toFixed(3), 1)}s (${util.pad(Number.parseFloat(reaction_time_ms).toFixed(2), 1)} ms after audio).`);&amp;#10;        psychoJS.experiment.addData(&quot;spacebar_rt_ms&quot;, spacebar_rt_ms);&amp;#10;        psychoJS.experiment.addData(&quot;reaction_time_ms&quot;, reaction_time_ms);&amp;#10;        continueRoutine = false;&amp;#10;    }&amp;#10;}&amp;#10;" valType="extendedCode" updates="constant" name="Each JS Frame"/>
        <Param val="" valType="extendedCode" updates="constant" name="End Experiment"/>
        <Param val="" valType="extendedCode" updates="constant" name="End JS Experiment"/>
        <Param val="psychoJS.eventManager.clearEvents({&quot;eventType&quot;: &quot;keyboard&quot;});&amp;#10;" valType="extendedCode" updates="constant" name="End JS Routine"/>
        <Param val="event.clearEvents(eventType='keyboard')&amp;#10;" valType="extendedCode" updates="constant" name="End Routine"/>
        <Param val="False" valType="bool" updates="None" name="disabled"/>
        <Param val="main_code" valType="code" updates="None" name="name"/>
      </CodeComponent>
