        <Param val="# Disable &quot;Siguiente&quot; at start&amp;#10;canContinue = False&amp;#10;boton_uso_3.opacity = 0.5&amp;#10;boton_uso_3.color = 'gray'&amp;#10;" valType="extendedCode" updates="constant" name="Begin Routine"/>
        <Param val="Auto-&gt;JS" valType="str" updates="None" name="Code Type"/>
        <Param val="# List of all slider components in this routine&amp;#10;sliders = [&amp;#10;    porc_mismo_que,&amp;#10;    porc_mismo_esp,&amp;#10;    porc_mismo_otr,&amp;#10;    porc_calculos_que,&amp;#10;    porc_calculos_esp,&amp;#10;    porc_calculos_otr&amp;#10;]&amp;#10;&amp;#10;# Check if all sliders have a response&amp;#10;filled = all(sl.getRating() is not None for sl in sliders)&amp;#10;&amp;#10;# Enable &quot;Siguiente&quot; button once all are filled&amp;#10;if filled and not canContinue:&amp;#10;    canContinue = True&amp;#10;    boton_uso_3.opacity = 1&amp;#10;    boton_uso_3.color = 'white'&amp;#10;elif not filled:&amp;#10;    canContinue = False&amp;#10;    boton_uso_3.opacity = 0.5&amp;#10;    boton_uso_3.color = 'gray'&amp;#10;&amp;#10;# Allow next only when all responses are made&amp;#10;if boton_uso_3.isClicked and canContinue:&amp;#10;    continueRoutine = False&amp;#10;" valType="extendedCode" updates="constant" name="Each Frame"/>
        <Param val="/* Syntax Error: Fix Python code */" valType="extendedCode" updates="constant" name="Each JS Frame"/>
        <Param val="" valType="extendedCode" updates="constant" name="End Experiment"/>
        <Param val="" valType="extendedCode" updates="constant" name="End JS Experiment"/>
        <Param val="" valType="extendedCode" updates="constant" name="End JS Routine"/>
        <Param val="" valType="extendedCode" updates="constant" name="End Routine"/>
